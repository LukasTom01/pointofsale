# --- Databáze ---
# Když je DATABASE_URL nastavené, aplikace používá Postgres (Neon).
# Když prázdné/nenastavené, používá lokální souborové úložiště (data/db.json).
#
# Neon connection string získáte na https://neon.tech (Dashboard → Connection string).
# Použijte "pooled" connection string (obsahuje -pooler), končí na ?sslmode=require
DATABASE_URL=""

# --- Platba kartou přes Adyen Terminal API (volitelné) ---
# Dokud není vyplněno (a ADYEN_SIMULATE není 1), appka používá "ruční potvrzení".
#
# DISH Pay běží na Adyenu – pokud od DISH získáte API key, merchant account a
# POIID k jejich terminálu, funguje tohle napojení rovnou na DISH PAY NOW.
# Jinak platí pro vlastní Adyen účet + Adyen terminál.
ADYEN_API_KEY=""
ADYEN_POI_ID=""            # ID terminálu, např. "V400m-123456789"
ADYEN_SALE_ID="pos-stand"  # ID pokladny (naše volba)
ADYEN_ENVIRONMENT="test"   # "test" nebo "live"
ADYEN_LIVE_PREFIX=""       # povinné jen pro live (z Adyen Customer Area)

# Simulační režim pro vývoj bez terminálu: schválí platbu bez volání Adyenu.
# Nastavte na "1" pro vyzkoušení průběhu; na ostro nechte prázdné.
ADYEN_SIMULATE=""
